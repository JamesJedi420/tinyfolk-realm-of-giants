# Normalize text files consistently in this repository.
* text=auto eol=lf

# Source and config files should always stay LF.
*.luau text eol=lf
*.lua text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ps1 text eol=lf

# Binary assets should never be line-normalized.
*.rbxl binary
*.rbxlx binary
*.rbxm binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp3 binary
*.ogg binary
*.wav binary
*.zip binary
*.7z binary
